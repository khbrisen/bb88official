---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Contact Babu88 customer support 24/7 via live chat, email, or phone.">
  <section class="hero" style="background-image:url('/images/banner.webp');background-blend-mode:multiply;">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Our customer support team is available 24/7 to assist you with any inquiries or issues you may encounter.</p>
      <p>The quickest way to reach us is via <strong>BABU88 live chat</strong>. Alternatively, you can reach us via email (<a href="mailto:admin@babu88.com" style="color:#ffce01;">admin@babu88.com</a>).</p>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <div class="contact-cards">
        <div class="contact-card">
          <h3 style="font-size:1.1rem;margin-bottom:16px;">Bangladesh</h3>
          <p>+88-013-929-31554</p>
          <p>admin@babu88.com</p>
          <p><strong>Dhaka, Bangladesh</strong></p>
        </div>
        <div class="contact-card">
          <h3 style="font-size:1.1rem;margin-bottom:16px;">India</h3>
          <p>+91-855-522-8792</p>
          <p>admin@babu88.com</p>
          <p><strong>New Delhi, India</strong></p>
        </div>
        <div class="contact-card">
          <h3 style="font-size:1.1rem;margin-bottom:16px;">Nepal</h3>
          <p>+977-9841-234567</p>
          <p>admin@babu88.com</p>
          <p><strong>Kathmandu, Nepal</strong></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="text-align:center;">
    <div class="container" style="max-width:700px;">
      <h2>Get in Touch</h2>
      <p>Get in touch directly with the team at Babu88 by emailing us at <a href="mailto:admin@babu88.com">admin@babu88.com</a>.</p>
      <p>You can expect a response from our team via email within 2-3 working days.</p>
    </div>
  </section>

  <section class="section section--gold" style="text-align:center;">
    <div class="container">
      <h2>Reach Out To Us</h2>
      <hr style="width:30%;margin:0 auto 16px;border-color:#000;" />
      <p>We're committed to helping you. Reach out anytime with your questions and feedback.</p>
      <a href="mailto:admin@babu88.com" class="cta-button" style="margin-top:8px;">Email Us</a>
    </div>
  </section>
</BaseLayout>

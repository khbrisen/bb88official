---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description = 'Babu88 is South Asia\'s favourite online casino and sports betting platform.', canonical } = Astro.props;
const pageTitle = title === 'Home' ? 'Babu88Official - South Asia\'s Favourite Online Casino' : `${title} | Babu88Official`;
const siteUrl = 'https://babu88official.com';
const ogImage = `${siteUrl}/images/Babu88Offical-Banner.webp`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  {canonical && <link rel="canonical" href={canonical} />}
  <link rel="icon" type="image/png" href="/images/cropped-babu88_fbprofile_logo-1.jpg" />

  <!-- Preconnect to Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@200;400;600;700&family=Open+Sans:wght@400;500;700&family=Righteous&family=Josefin+Sans&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical || siteUrl} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <slot name="schema" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
